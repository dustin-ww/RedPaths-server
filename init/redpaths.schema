# - "has_gpo_link" (Domain/DirectoryNode → GPOLink)

# ========================================
# ATTACK
# ========================================
attack.attack_id: string @index(exact) @upsert .
attack.name: string @index(exact, term) .
attack.cost: int @index(int) .
attack.noise: float @index(float) .
attack.reliability: float @index(float) .

type Attack {
  attack.attack_id
  attack.name
  attack.cost
  attack.noise
  attack.reliability
  dgraph.type
}
# Via Assertions:
# - "requires" (Attack → Capability/Credential)
# - "grants" (Attack → Capability)
# - "targets" (Attack → Principal/Host)
# - "produces" (Attack → Credential)

# ========================================
# ATTACK RESULT
# ========================================
attack_result.success: bool @index(bool) .
attack_result.noise_generated: float .

type AttackResult {
  attack_result.success
  attack_result.noise_generated
  created_at
  dgraph.type
}
# Via Assertions:
# - "executed_attack" (AttackResult → Attack)
# - "compromised" (AttackResult → Principal/Host/Credential)

# ========================================
# ATTACK STATE (Simulation State)
# ========================================
attack_state.timestamp: datetime @index(hour) .
attack_state.total_noise: float .
attack_state.total_cost: int .

type AttackState {
  attack_state.timestamp
  attack_state.total_noise
  attack_state.total_cost
  dgraph.type
}
# Via Assertions:
# - "has_history" (AttackState → AttackResult)
# - "has_capability" (AttackState → Capability)

# ========================================
# COMPROMISE RECORD
# ========================================
compromise_record.compromised_at: datetime @index(hour) .
compromise_record.noise_generated: float .
compromise_record.cost: int .

type CompromiseRecord {
  compromise_record.compromised_at
  compromise_record.noise_generated
  compromise_record.cost
  dgraph.type
}
# Via Assertions:
# - "compromised_principal" (CompromiseRecord → Principal)
# - "compromised_host" (CompromiseRecord → Host)
# - "via_attack" (CompromiseRecord → Attack)
# - "parent_of" (CompromiseRecord → CompromiseRecord) - Attack-Chain

# ========================================
# TARGET (Red Team Target)
# ========================================
target.ip: string @index(exact) .
target.cidr: int .
target.note: string .
target.is_verified: bool @index(bool) .

type Target {
  target.ip
  target.cidr
  target.note
  target.is_verified
  created_at
  modified_at
  validated_at
  validated_by
  discovered_at
  discovered_by
  dgraph.type
}
# Via Assertions:
# - "targets" (Target → Host)
# - "has_target" (Project → Target)