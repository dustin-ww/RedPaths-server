# ========================================
# SESSION
# ========================================
session.session_type: string @index(exact, term) .
session.is_active: bool @index(bool) .
session.login_time: datetime @index(hour) .

type Session {
  session.session_type
  session.is_active
  session.login_time
  created_at
  modified_at
  validated_at
  validated_by
  discovered_at
  discovered_by
  dgraph.type
}
# Via Assertions:
# - "on_host" / "hosts_session" (Session → Host)
# - "exposes" (Session → Credential)
# - "authenticated_as" (Session → User)

# ========================================
# CAPABILITY
# ========================================
capability.name: string @index(exact, term) .
capability.scope: string @index(exact, term) .
capability.risk_level: int @index(int) .

type Capability {
  capability.name
  capability.scope
  capability.risk_level
  dgraph.type
}
# Via Assertions:
# - "applies_to" (Capability → Any)
# - "has_capability" (Principal → Capability)
# - "grants_capability" (ACE/GPO → Capability)

# ========================================
# ACL (Access Control List)
# ========================================

acl.name: string @index(exact, term) .

type ACL {
  acl.name
  created_at
  modified_at
  validated_at
  validated_by
  discovered_at
  discovered_by
  dgraph.type
}
# Via Assertions:
# - "owned_by" (ACL → Principal)
# - "contains" (ACL → ACE)
# - "has_acl" (Any → ACL)

# ========================================
# ACE (Access Control Entry)
# ========================================
ace.access_type: string @index(exact, term) .
ace.inherited: bool @index(bool) .
ace.applies_to: string @index(term) .

type ACE {
  ace.access_type
  ace.inherited
  ace.applies_to
  created_at
  modified_at
  validated_at
  validated_by
  discovered_at
  discovered_by
  dgraph.type
}
# Via Assertions:
# - "has_right" (ACE → ADRight)
# - "granted_to" (ACE → Principal)
# - "derives" (ACE → Capability)
# - "contained_in" (ACE → ACL)

# ========================================
# AD RIGHT
# ========================================
ad_right.name: string @index(exact) @upsert .
ad_right.category: string @index(exact, term) .
ad_right.risk_level: int @index(int) .

type ADRight {
  ad_right.name
  ad_right.category
  ad_right.risk_level
  dgraph.type
}
# Via Assertions:
# - "implies" (ADRight → Capability)

# ========================================
# GPO (Group Policy Object)
# ========================================
gpo.name: string @index(exact, term) .
gpo.description: string .
gpo.has_acl: uid @reverse .

