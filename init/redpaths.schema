  gpo.name
  gpo.description
  gpo.has_acl
  created_at
  modified_at
  validated_at
  validated_by
  discovered_at
  discovered_by
  dgraph.type
}
# Via Assertions:
# - "contains" (GPO → GPOSetting)
# - "grants" (GPO → Capability)
# - "has_acl" (GPO → ACL)

